# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase - create a project at https://supabase.com and copy these from Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Pinata IPFS - create a JWT at https://app.pinata.cloud/developers/api-keys.
PINATA_JWT=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# Thirdweb - create a project at https://thirdweb.com/dashboard/settings/api-keys.
THIRDWEB_SECRET_KEY=
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=

# WalletConnect - create a project ID at https://cloud.walletconnect.com.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Base Sepolia RPC - use a provider endpoint for Base Sepolia.
NEXT_PUBLIC_CHAIN_ID=84532
BASE_SEPOLIA_RPC_URL=

# Server-only application secrets. Generate strong random values before deployment.
ENCRYPTION_SECRET=
RATE_LIMIT_SECRET=
