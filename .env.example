# No wallet / no MetaMask demo mode.
# This lets the app run and click through without deploying a contract.
NEXT_PUBLIC_DEMO_MODE=true

# Optional in demo mode. Needed only if you want real Pinata uploads.
PINATA_JWT=dummy

# Leave blank unless deploying the contract for real.
PRIVATE_KEY=dummy
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_MARKETPLACE_CONTRACT_ADDRESS=dummy

# Optional / future Supabase fields
NEXT_PUBLIC_SUPABASE_URL=dummy
NEXT_PUBLIC_SUPABASE_ANON_KEY=dummy
SUPABASE_SERVICE_ROLE_KEY=dummy
