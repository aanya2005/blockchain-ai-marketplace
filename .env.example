# Required for IPFS uploads through /api/pinata
PINATA_JWT=your_pinata_jwt_here

# Required after deploying the contract
NEXT_PUBLIC_MARKETPLACE_CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Required only for contract deployment
PRIVATE_KEY=your_testnet_wallet_private_key_without_0x
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional Supabase placeholders for later metadata/user features
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
